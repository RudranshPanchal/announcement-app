{% assign announcement = shop.metafields.announcement.banner_text.value %}

{% if announcement != blank %}
  <div class="announcement-banner">
    {{ announcement }}
  </div>
{% endif %}

<style>
.announcement-banner {
  width: 100%;
  background: #111827;
  color: white;
  text-align: center;
  padding: 14px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 6px;
}
</style>

{% schema %}
{
  "name": "Announcement Banner",
  "target": "section",
  "settings": []
}
{% endschema %}